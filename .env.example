JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
GITHUB_TOKEN=your-github-personal-access-token
# Backend port (the frontend proxy follows this automatically). Default 3000.
PORT=3000
# Frontend dev-server port. Default 5180. Change if it collides with another app.
FRONTEND_PORT=5180
